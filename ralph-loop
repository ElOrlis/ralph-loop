#!/usr/bin/env bash

# Ralph Loop - Interactive PRD Completion Tool
# Iteratively calls Claude to complete complex PRDs one task at a time

set -euo pipefail

# Resolve the directory containing this script so lib/ lookups work regardless of CWD
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Default values
MAX_ITERATIONS=15
VERBOSE=false
DEBUG=false
RESUME=false
ANALYZE_PRD=false
DRY_RUN=false
GITHUB_ENABLED=true
REPO_OVERRIDE=""
TARGET_REPO=""
PRD_FILE=""
JSON_FILE=""
PROGRESS_FILE=""

