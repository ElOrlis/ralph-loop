# Ralph Loop - Interactive PRD Completion Tool
# Iteratively calls Claude to complete complex PRDs one task at a time

set -euo pipefail

# Resolve the directory containing this script so lib/ lookups work regardless of CWD
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Default values
MAX_ITERATIONS=15
VERBOSE=false
DEBUG=false
RESUME=false
ANALYZE_PRD=false
REPORT_MODE=false
DRY_RUN=false
GITHUB_ENABLED=true
MCP_ENABLED=false
MCP_CONFIG_FILE=""
AGENT="claude"
AGENT_EXPLICIT=false
REVIEWER="none"
STATE_DIR=""
STATE_DIR_OVERRIDE=""
MIGRATE_STATE=false
SOURCE_REL_PATH=""
REPO_OVERRIDE=""
TARGET_REPO=""
GITHUB_API_CALLS=0
GITHUB_API_WARN_THRESHOLD=100
GITHUB_API_WARNED=false
BRANCH_ENABLED=true
ORIGINAL_BRANCH=""
CURRENT_TASK_BRANCH=""
STASH_APPLIED=false
PRD_FILE=""
JSON_FILE=""
PROGRESS_FILE=""

